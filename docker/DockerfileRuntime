ARG DEVICE=latest

FROM mdnf1992/cpp-dev:${DEVICE} AS build

COPY . /src

RUN mkdir -p /src/build && cd /src/build && \
    cmake .. -DCMAKE_INSTALL_PREFIX=/app -DIMPORT_ALL_RUNTIME=OFF -DBUILD_TESTING=OFF && \
    make -j4 install

FROM debian:trixie-slim AS runtime

COPY --from=build /app /usr/local
# If using Docker BuildKit, set mode on copy:
COPY --from=build --chmod=0755 /src/docker/entrypoint.sh /usr/local/bin/entrypoint.sh

# Fallback (uncomment if not using BuildKit):
# COPY --from=build /src/docker/entrypoint.sh /usr/local/bin/entrypoint.sh
# RUN chmod +x /usr/local/bin/entrypoint.sh

RUN ldconfig

# Various targets
FROM runtime AS rplidar 

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]

